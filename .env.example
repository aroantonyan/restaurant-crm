# Restaurant CRM — environment template
#
# Copy to `.env` (which is gitignored) and fill in real values before
# running `docker compose up`. Keys marked REQUIRED have no safe default.

# ─── Postgres ───────────────────────────────────────────────────────────
POSTGRES_DB=RestaurantDB
POSTGRES_USER=postgres
# REQUIRED — generate with:  openssl rand -base64 32
POSTGRES_PASSWORD=

# ─── JWT (ASP.NET Core auth) ────────────────────────────────────────────
# REQUIRED — must be ≥ 32 characters. Generate with:
#   openssl rand -base64 48
JWT_SECRET=
JWT_ISSUER=RestaurantCRM
JWT_AUDIENCE=RestaurantCRM
JWT_EXPIRY_HOURS=12

# ─── Frontend ───────────────────────────────────────────────────────────
# The host port nginx is published on (local docker-compose.yml only). Pick
# anything free locally; in production Caddy owns 80/443 and the web container
# is not published to the host at all.
WEB_PORT=8080

# ─── Deploy (production / docker-compose.prod.yml only) ──────────────────
# Which image build to run. Defaults to :latest (the most recent CI push).
# To roll back, set this to a specific build, e.g. IMAGE_TAG=sha-1a2b3c4
# (CI tags every build with its short git SHA), then re-run:
#   docker compose -f docker-compose.prod.yml up -d
# IMAGE_TAG=latest
